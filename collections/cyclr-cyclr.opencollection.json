            "method": "GET",
            "url": "https://api.cyclr.com/v1.0/accounts",
            "params": [
              {
                "name": "page",
                "value": "",
                "type": "query",
                "description": "Page number for pagination"
              },
              {
                "name": "pageSize",
                "value": "",
                "type": "query",
                "description": "Number of results per page"
              }
            ]
          },
          "docs": "Retrieve a list of all Cyclr accounts under the partner."
